# 필수: PC 카카오톡에서 검색 가능한 단톡방 이름
TARGET_CHATROOM=병무청뉴스방

# true로 두면 기본 실행도 게시합니다. 처음에는 false + --dry-run으로 점검하세요.
KAKAO_ENABLED=false
KAKAO_APP_PATH=C:\Program Files (x86)\Kakao\KakaoTalk\KakaoTalk.exe
KAKAO_WINDOW_TITLES=KakaoTalk,카카오톡
KAKAO_SEARCH_HOTKEY=ctrl,f
KAKAO_SEND_ENTER=true
KAKAO_MAX_CHUNK_CHARS=3500
KAKAO_WAIT_SECONDS=8
KAKAO_STEP_DELAY_SECONDS=0.7

# Ctrl+F 검색이 PC 카카오톡 환경에서 잘 안 먹으면 좌표 클릭을 사용하세요.
# KAKAO_SEARCH_CLICK_X=
# KAKAO_SEARCH_CLICK_Y=
# KAKAO_MESSAGE_CLICK_X=
# KAKAO_MESSAGE_CLICK_Y=

# 요약 엔진:
# - auto: OPENAI_API_KEY가 있으면 OpenAI API, 없으면 간단 요약
# - codex: 로그인된 로컬 Codex CLI를 LLM으로 사용
# - openai: OpenAI API만 사용
# - heuristic: API/LLM 없이 간단 요약만 사용
SUMMARY_PROVIDER=auto

# SUMMARY_PROVIDER=codex일 때 사용합니다.
CODEX_COMMAND=codex.cmd
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=300

# 음성 요약 생성과 GitHub Pages 플레이어 링크
TTS_PROVIDER=edge
TTS_VOICE=ko-KR-SunHiNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz
PODCAST_BASE_URL=https://YOUR_GITHUB_USER.github.io/YOUR_REPO/podcast/

# SUMMARY_PROVIDER=auto/openai에서 OpenAI 키가 있으면 더 좋은 종합 요약을 생성합니다.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 기본 뉴스 수집은 k-skill naver-news-search 프록시를 사용합니다.
# NAVER_CLIENT_ID/SECRET이 있으면 공식 네이버 Open API를 직접 호출하고,
# 없으면 KSKILL_PROXY_BASE_URL 경유로 호출합니다.
NAVER_NEWS_ENABLED=true
KSKILL_PROXY_BASE_URL=https://k-skill-proxy.nomadamas.org
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

NEWS_QUERY_TERMS=병무청,병역,입영,사회복무요원,예비군,병역판정검사,현역병
# 비워 두면 넓게 수집합니다. 기본값은 병무청 직접 관련 기사만 남깁니다.
NEWS_REQUIRED_TERMS=병무청
NEWS_MAX_ITEMS=40
NEWS_LOOKBACK_DAYS=2
GOOGLE_NEWS_ENABLED=false
POLICY_RSS_ENABLED=false
POLICY_RSS_URLS=https://www.korea.kr/rss/pressrelease.xml
FETCH_ARTICLE_TEXT=false
REQUEST_TIMEOUT_SECONDS=15
OUTPUT_DIR=runs
