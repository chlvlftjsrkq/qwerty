name: Daily MMA News Kakao Post

on:
  workflow_dispatch:
  schedule:
    # 08:00 KST
    - cron: "0 23 * * *"

jobs:
  post:
    runs-on: [self-hosted, Windows, X64]
    steps:
      - uses: actions/checkout@v4
      - name: Install dependencies
        run: |
          python -m pip install -r requirements.txt
          python -m pip install "git+https://github.com/kronenz/kakaotalk-mcp.git@master"
      - name: Build summary
        env:
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          OPENAI_MODEL: ${{ vars.OPENAI_MODEL || 'gpt-4.1-mini' }}
          NAVER_NEWS_ENABLED: "true"
          GOOGLE_NEWS_ENABLED: "false"
          POLICY_RSS_ENABLED: "false"
          KSKILL_PROXY_BASE_URL: ${{ vars.KSKILL_PROXY_BASE_URL || 'https://k-skill-proxy.nomadamas.org' }}
        run: python -m kakao_mma_news --dry-run
      - name: Post to KakaoTalk via MCP
        env:
          TARGET_CHATROOM: ${{ vars.TARGET_CHATROOM }}
        run: |
          $summary = Get-ChildItem -Path runs -Filter "summary-*.md" | Sort-Object LastWriteTime -Descending | Select-Object -First 1
          python scripts/post_summary_mcp.py --room "$env:TARGET_CHATROOM" --summary "$($summary.FullName)" --verify
